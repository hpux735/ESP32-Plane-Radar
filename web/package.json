{
  "name": "plane-radar-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser preview of the ESP32 plane-radar desk toy. Renders the same round radar view in a canvas so friends can try it without hardware.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.0.0",
    "@types/node": "^26.1.1",
    "typescript": "~5.5.4",
    "vite": "^5.4.10",
    "vitest": "^4.1.10",
    "wrangler": "^4.0.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
